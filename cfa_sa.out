Mplus VERSION 8.10
MUTHEN & MUTHEN
04/22/2026   7:30 PM

INPUT INSTRUCTIONS

  DATA:   FILE = application_example.dat;
    VARIABLE:
        names = ID SA11-SA18
                   SA21-SA28
                   SA31-SA38
                   LS11-LS15
                   LS21-LS25
                   LS31-LS35;

      USEVARIABLES = SA12 SA14 SA15-SA16
                     !LS11-LS15
                     SA22 SA24 SA25-SA26
                     !LS21-LS25
                     SA32 SA34 SA35-SA36
                     !LS31-LS35
                     ;

    analysis:
    estimator = ml;
    RITERATIONS = 5000;
    !STARTS = 500;

  MODEL:

      ! Factor loadings — free all with *, label all (effects coding)
      SA1 BY SA12* (L1_12)
             SA14  (L1_14)
             SA15  (L1_15)
             SA16  (L1_16);

      SA2 BY SA22* (L2_22)
             SA24  (L2_24)
             SA25  (L2_25)
             SA26  (L2_26);

      SA3 BY SA32* (L3_32)
             SA34  (L3_34)
             SA35  (L3_35)
             SA36  (L3_36);

      ! Factor variances and means (both freely estimated under full effects coding)
      SA1 (v1);
      SA2 (v2);
      SA3 (v3);
      [SA1*];
      [SA2*];
      [SA3*];

      ! Factor correlations
      SA1 WITH SA2;
      SA1 WITH SA3;
      SA2 WITH SA3;

      ! Indicator intercepts — effects coding will constrain per-factor sum = 0
      [SA12] (I1_12); [SA14] (I1_14); [SA15] (I1_15); [SA16] (I1_16);
      [SA22] (I2_22); [SA24] (I2_24); [SA25] (I2_25); [SA26] (I2_26);
      [SA32] (I3_32); [SA34] (I3_34); [SA35] (I3_35); [SA36] (I3_36);

      ! Indicator residual variances
      SA12 (r1_12); SA14 (r1_14); SA15 (r1_15); SA16 (r1_16);
      SA22 (r2_22); SA24 (r2_24); SA25 (r2_25); SA26 (r2_26);
      SA32 (r3_32); SA34 (r3_34); SA35 (r3_35); SA36 (r3_36);

      ! Correlated uniquenesses (same item across waves)
      SA12 WITH SA22 SA32;
      SA22 WITH SA32;

      SA14 WITH SA24 SA34;
      SA24 WITH SA34;

      SA15 WITH SA25 SA35;
      SA25 WITH SA35;

      SA16 WITH SA26 SA36;
      SA26 WITH SA36;

  MODEL CONSTRAINT:
      ! Effects coding on loadings: sum of loadings = 4 per factor (average = 1)
      L1_12 = 4 - L1_14 - L1_15 - L1_16;
      L2_22 = 4 - L2_24 - L2_25 - L2_26;
      L3_32 = 4 - L3_34 - L3_35 - L3_36;

      ! Effects coding on intercepts: sum of intercepts = 0 per factor (average = 0)
      I1_12 = 0 - I1_14 - I1_15 - I1_16;
      I2_22 = 0 - I2_24 - I2_25 - I2_26;
      I3_32 = 0 - I3_34 - I3_35 - I3_36;

      NEW(sumload1 sumload2 sumload3
          sumresid1 sumresid2 sumresid3
          omega_SA1 omega_SA2 omega_SA3);

      ! Sum of loadings per factor (= 4 by construction, computed explicitly)
      sumload1 = L1_12 + L1_14 + L1_15 + L1_16;
      sumload2 = L2_22 + L2_24 + L2_25 + L2_26;
      sumload3 = L3_32 + L3_34 + L3_35 + L3_36;

      ! Sum of within-wave residual variances
      sumresid1 = r1_12 + r1_14 + r1_15 + r1_16;
      sumresid2 = r2_22 + r2_24 + r2_25 + r2_26;
      sumresid3 = r3_32 + r3_34 + r3_35 + r3_36;

      ! Omega per wave (McDonald, 1999)
      omega_SA1 = (sumload1**2) * v1 / ((sumload1**2) * v1 + sumresid1);
      omega_SA2 = (sumload2**2) * v2 / ((sumload2**2) * v2 + sumresid2);
      omega_SA3 = (sumload3**2) * v3 / ((sumload3**2) * v3 + sumresid3);


    OUTPUT: tech1 tech4 stdyx residual cinterval;



