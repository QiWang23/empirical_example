Mplus VERSION 8.10
MUTHEN & MUTHEN
04/22/2026   8:55 PM

INPUT INSTRUCTIONS

  DATA:   FILE = application_example.dat;
  DEFINE:
      cx1 = SUM(SA12 SA14 SA15 SA16);
      cx2 = SUM(SA22 SA24 SA25 SA26);
      cx3 = SUM(SA32 SA34 SA35 SA36);
      cy1 = SUM(LS11 LS12 LS13 LS14 LS15);
      cy2 = SUM(LS21 LS22 LS23 LS24 LS25);
      cy3 = SUM(LS31 LS32 LS33 LS34 LS35);
    VARIABLE:
        names = ID SA11-SA18
                   SA21-SA28
                   SA31-SA38
                   LS11-LS15
                   LS21-LS25
                   LS31-LS35;

      USEVARIABLES = cx1 cx2 cx3 cy1 cy2 cy3;
      ANALYSIS:
          ESTIMATOR = ML;
          MODEL = NOCOV;

      MODEL:
          FX1 BY cx1@1;
          FX2 BY cx2@1;
          FX3 BY cx3@1;
          FY1 BY cy1@1;
          FY2 BY cy2@1;
          FY3 BY cy3@1;
          cx1@4.768468;
          cx2@4.606809;
          cx3@4.708867;
          cy1@5.945507;
          cy2@5.563290;
          cy3@5.873337;
          RIX BY FX1@1 FX2@1 FX3@1;
          RIY BY FY1@1 FY2@1 FY3@1;
          FX1@0;
          FY1@0;
          FX2@0;
          FY2@0;
          FX3@0;
          FY3@0;
          RIX WITH RIY;
          WFX1 BY FX1@1;
          WFY1 BY FY1@1;
          WFX2 BY FX2@1;
          WFY2 BY FY2@1;
          WFX3 BY FX3@1;
          WFY3 BY FY3@1;
          ! -------- Structural paths --------
          ! Wave 2
          WFX2 ON WFX1;   ! WFX2 ON WFX1  [see note]
          WFX2 ON WFY1;
          WFY2 ON WFX1;
          WFY2 ON WFY1;

          ! Wave 3
          WFX3 ON WFX2;
          WFX3 ON WFY2;
          WFY3 ON WFX2;
          WFY3 ON WFY2;

          WFX1 with WFY1;
          WFX2 with WFY2;
          WFX3 with WFY3;

  output: TECH1 STDYX SAMPSTAT CINTERVAL;



