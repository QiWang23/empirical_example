Mplus VERSION 8.10
MUTHEN & MUTHEN
04/22/2026   8:16 PM

INPUT INSTRUCTIONS

  DATA:   FILE = application_example.dat;
    VARIABLE:
        names = ID SA11-SA18
                   SA21-SA28
                   SA31-SA38
                   LS11-LS15
                   LS21-LS25
                   LS31-LS35;

      USEVARIABLES = SA12 SA14 SA15-SA16
                     LS11-LS15
                     SA22 SA24 SA25-SA26
                     LS21-LS25
                     SA32 SA34 SA35-SA36
                     LS31-LS35
                     ;
    analysis:
    estimator = ml;
    MODEL = NOCOV;


  MODEL:

    ! LS factors (tidied labels to match item numbers)
      LS1 BY LS11* LS12-LS15 (LX11-LX15);
      LS2 BY LS21* LS22-LS25 (LX21-LX25);
      LS3 BY LS31* LS32-LS35 (LX31-LX35);

      ! SA factors
      SA1 BY SA12* SA14 SA15-SA16 (LY11-LY14);
      SA2 BY SA22* SA24 SA25-SA26 (LY21-LY24);
      SA3 BY SA32* SA34 SA35-SA36 (LY31-LY34);


       wx1 by LS1@1;
       wx2 by LS2@1;
       wx3 by LS3@1;

       wy1 by SA1@1;
       wy2 by SA2@1;
       wy3 by SA3@1;

       ! Constrain measurement error variances to 0
       LS1-SA3@0;

      ! ---------- Intercepts (effects-coding identification) ----------
      ! LS indicators (5 per wave)
      [LS11] (IX11); [LS12] (IX12); [LS13] (IX13); [LS14] (IX14); [LS15] (IX15);
      [LS21] (IX21); [LS22] (IX22); [LS23] (IX23); [LS24] (IX24); [LS25] (IX25);
      [LS31] (IX31); [LS32] (IX32); [LS33] (IX33); [LS34] (IX34); [LS35] (IX35);

      ! SA indicators (4 per wave)
      [SA12] (IY11); [SA14] (IY12); [SA15] (IY13); [SA16] (IY14);
      [SA22] (IY21); [SA24] (IY22); [SA25] (IY23); [SA26] (IY24);
      [SA32] (IY31); [SA34] (IY32); [SA35] (IY33); [SA36] (IY34);

      [wx1* wx2* wx3*];
      [wy1* wy2* wy3*];


      ! ---------------------------------------------------------------
      ! Estimate lagged effects between within-person centered variables
      wx2 wy2 on wx1 wy1;
      wx3 wy3 on wx2 wy2;


      ! Estimate covariance between within-person components at first wave
      wx1 WITH wy1;

      ! Estimate covariances between residuals of within-person components
      ! (i.e., innovations)
      wx2 WITH wy2;
      wx3 WITH wy3;


      ! Correlated uniquenesses (cross-wave, same item)
      SA12 WITH SA22 SA32;
      SA22 WITH SA32;

      SA14 WITH SA24 SA34;
      SA24 WITH SA34;

      SA15 WITH SA25 SA35;
      SA25 WITH SA35;

      SA16 WITH SA26 SA36;
      SA26 WITH SA36;

      LS11 WITH LS21 LS31;
      LS21 WITH LS31;

      LS12 WITH LS22 LS32;
      LS22 WITH LS32;

      LS13 WITH LS23 LS33;
      LS23 WITH LS33;

      LS14 WITH LS24 LS34;
      LS24 WITH LS34;

      LS15 WITH LS25 LS35;
      LS25 WITH LS35;


  MODEL CONSTRAINT:
      ! LS has 5 items -> sum(loadings) = 5 per wave
      LX15 = 5 - LX11 - LX12 - LX13 - LX14;
      LX25 = 5 - LX21 - LX22 - LX23 - LX24;
      LX35 = 5 - LX31 - LX32 - LX33 - LX34;

      ! SA has 4 items -> sum(loadings) = 4 per wave
      LY14 = 4 - LY11 - LY12 - LY13;
      LY24 = 4 - LY21 - LY22 - LY23;
      LY34 = 4 - LY31 - LY32 - LY33;

      ! LS has 5 items -> sum(intercepts) = 0 per wave
      IX15 = 0 - IX11 - IX12 - IX13 - IX14;
      IX25 = 0 - IX21 - IX22 - IX23 - IX24;
      IX35 = 0 - IX31 - IX32 - IX33 - IX34;

      ! SA has 4 items -> sum(intercepts) = 0 per wave
      IY14 = 0 - IY11 - IY12 - IY13;
      IY24 = 0 - IY21 - IY22 - IY23;
      IY34 = 0 - IY31 - IY32 - IY33;

    OUTPUT: tech1 tech4 stdyx residual cinterval;



