Mplus VERSION 8.10
MUTHEN & MUTHEN
04/22/2026   7:30 PM

INPUT INSTRUCTIONS

  DATA:   FILE = application_example.dat;
    VARIABLE:
        names = ID SA11-SA18
                   SA21-SA28
                   SA31-SA38
                   LS11-LS15
                   LS21-LS25
                   LS31-LS35;

      USEVARIABLES =
                     LS11-LS15

                     LS21-LS25

                     LS31-LS35
                     ;

    analysis:
    estimator = ml;
    RITERATIONS = 5000;
    !STARTS = 500;

  MODEL:

  ! Factor loadings — free all with *, label all (effects coding identifies scale)
      LS1 BY LS11* (L1_1)
             LS12  (L1_2)
             LS13  (L1_3)
             LS14  (L1_4)
             LS15  (L1_5);

      LS2 BY LS21* (L2_1)
             LS22  (L2_2)
             LS23  (L2_3)
             LS24  (L2_4)
             LS25  (L2_5);

      LS3 BY LS31* (L3_1)
             LS32  (L3_2)
             LS33  (L3_3)
             LS34  (L3_4)
             LS35  (L3_5);

      ! Factor variances and means (both freely estimated under effects coding)
      LS1 (v1);
      LS2 (v2);
      LS3 (v3);
      [LS1*];
      [LS2*];
      [LS3*];

      ! Factor correlations
      LS1 WITH LS2;
      LS1 WITH LS3;
      LS2 WITH LS3;

      ! Indicator intercepts — effects coding will constrain per-factor sum = 0
      [LS11] (I1_1); [LS12] (I1_2); [LS13] (I1_3); [LS14] (I1_4); [LS15] (I1_5);
      [LS21] (I2_1); [LS22] (I2_2); [LS23] (I2_3); [LS24] (I2_4); [LS25] (I2_5);
      [LS31] (I3_1); [LS32] (I3_2); [LS33] (I3_3); [LS34] (I3_4); [LS35] (I3_5);

      ! Indicator residual variances
      LS11 (r1_1); LS12 (r1_2); LS13 (r1_3); LS14 (r1_4); LS15 (r1_5);
      LS21 (r2_1); LS22 (r2_2); LS23 (r2_3); LS24 (r2_4); LS25 (r2_5);
      LS31 (r3_1); LS32 (r3_2); LS33 (r3_3); LS34 (r3_4); LS35 (r3_5);

      ! Correlated uniquenesses for LS (all waves)
      LS11 WITH LS21 LS31;
      LS21 WITH LS31;

      LS12 WITH LS22 LS32;
      LS22 WITH LS32;

      LS13 WITH LS23 LS33;
      LS23 WITH LS33;

      LS14 WITH LS24 LS34;
      LS24 WITH LS34;

      LS15 WITH LS25 LS35;
      LS25 WITH LS35;

  MODEL CONSTRAINT:
      ! Effects coding on loadings: sum of loadings = 5 per factor (average = 1)
      L1_1 = 5 - L1_2 - L1_3 - L1_4 - L1_5;
      L2_1 = 5 - L2_2 - L2_3 - L2_4 - L2_5;
      L3_1 = 5 - L3_2 - L3_3 - L3_4 - L3_5;

      ! Effects coding on intercepts: sum of intercepts = 0 per factor (average = 0)
      I1_1 = 0 - I1_2 - I1_3 - I1_4 - I1_5;
      I2_1 = 0 - I2_2 - I2_3 - I2_4 - I2_5;
      I3_1 = 0 - I3_2 - I3_3 - I3_4 - I3_5;

      NEW(sumload1 sumload2 sumload3
          sumresid1 sumresid2 sumresid3
          omega_LS1 omega_LS2 omega_LS3);

      ! Sum of loadings per factor (equals 5 by construction, computed explicitly)
      sumload1 = L1_1 + L1_2 + L1_3 + L1_4 + L1_5;
      sumload2 = L2_1 + L2_2 + L2_3 + L2_4 + L2_5;
      sumload3 = L3_1 + L3_2 + L3_3 + L3_4 + L3_5;

      ! Sum of within-wave residual variances
      sumresid1 = r1_1 + r1_2 + r1_3 + r1_4 + r1_5;
      sumresid2 = r2_1 + r2_2 + r2_3 + r2_4 + r2_5;
      sumresid3 = r3_1 + r3_2 + r3_3 + r3_4 + r3_5;

      ! Omega (McDonald, 1999) — one per wave
      omega_LS1 = (sumload1**2) * v1 / ((sumload1**2) * v1 + sumresid1);
      omega_LS2 = (sumload2**2) * v2 / ((sumload2**2) * v2 + sumresid2);
      omega_LS3 = (sumload3**2) * v3 / ((sumload3**2) * v3 + sumresid3);

    OUTPUT: tech1 tech4 stdyx residual cinterval;



